NODE_ENV=development
PORT=4000

# Comma-separated list of allowed origins for CORS.
# The StudyTwin AI frontend's Vite dev server runs on http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# Rate limiting (applied to /api routes)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Supabase project: Settings > API in the Supabase dashboard.
# SUPABASE_SERVICE_ROLE_KEY is a secret with full DB access, bypassing RLS —
# server-side only, never send it to the frontend.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
